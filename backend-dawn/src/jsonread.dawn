# Reading fields out of a parsed request body (M6 knife 9). All accessors take
# the JObj entries map; presence checks support FastAPI's exclude_unset (PATCH)
# semantics — a key absent from the body is left untouched on update.
use std/map
use json/value.{Json, JObj, JBool, JNum, JInt, JStr, JArr, JNull}
use json/parser.{parse}

## Parse a request body into its top-level object entries. Err on non-objects.
pub fn body_obj(body: String) -> Result[Map[String, Json], String] !io = {
  let j = parse(body)?
  match j {
    JObj(m) -> Ok(m)
    _ -> Err("request body must be a JSON object")
  }
}

pub fn has(m: Map[String, Json], key: String) -> Bool =
  match map.get(m, key) {
    Some(_) -> true
    None -> false
  }

pub fn str_or(m: Map[String, Json], key: String, fallback: String) -> String =
  match map.get(m, key) {
    Some(JStr(s)) -> s
    _ -> fallback
  }

## A present, non-null string field → Some; absent or JSON null → None. Mirrors
## pydantic's exclude_unset + `if value is not None` PATCH semantics (an explicit
## `null` leaves the field untouched rather than blanking it).
pub fn opt_str(m: Map[String, Json], key: String) -> Option[String] =
  match map.get(m, key) {
    Some(JStr(s)) -> Some(s)
    _ -> None
  }

pub fn bool_or(m: Map[String, Json], key: String, fallback: Bool) -> Bool =
  match map.get(m, key) {
    Some(JBool(b)) -> b
    _ -> fallback
  }

## An optional integer field: absent or null → None, JInt/JNum → Some.
pub fn opt_int(m: Map[String, Json], key: String) -> Option[Int] =
  match map.get(m, key) {
    Some(JInt(n)) -> Some(n)
    Some(JNum(x)) -> Some(to_int(x))
    _ -> None
  }

## A string-list field (tags): absent → [], else the JStr items.
pub fn str_list(m: Map[String, Json], key: String) -> List[String] =
  match map.get(m, key) {
    Some(JArr(xs)) -> filter_map_str(xs)
    _ -> []
  }

fn filter_map_str(xs: List[Json]) -> List[String] =
  fold(xs, [], fn(acc, j) =>
      match j {
        JStr(s) -> acc ++ [s]
        _ -> acc
      })

test "reads fields and honors presence" {
  match body_obj("{\"title\":\"Hi\",\"published\":true,\"page_id\":3,\"tags\":[\"a\",\"b\"]}") {
    Ok(m) -> {
      assert str_or(m, "title", "") == "Hi"
      assert bool_or(m, "published", false)
      assert opt_int(m, "page_id") == Some(3)
      assert str_list(m, "tags") == ["a", "b"]
      assert has(m, "title")
      assert has(m, "missing") == false
      assert opt_int(m, "missing") == None
    }
    Err(e) -> panic(e)
  }
}

test "null page_id reads as None" {
  match body_obj("{\"page_id\":null}") {
    Ok(m) -> { assert opt_int(m, "page_id") == None }
    Err(e) -> panic(e)
  }
}

## An integer field, accepting a JSON number that happens to be integral.
## Distinct from `strict_int`, which the settings handler keeps local because it
## must reject a float the way FastAPI's isinstance(v, int) check does.
pub fn int_field(m: Map[String, Json], key: String) -> Option[Int] =
  match map.get(m, key) {
    Some(JInt(n)) -> Some(n)
    Some(JNum(x)) -> Some(to_int(x))
    _ -> None
  }

## A key present with an explicit JSON null — a non-optional str field rejects
## it (422), which is different from the key being absent (left untouched).
pub fn present_null(m: Map[String, Json], key: String) -> Bool =
  match map.get(m, key) {
    Some(JNull) -> true
    _ -> false
  }
