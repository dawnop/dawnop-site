# Qiniu Kodo request signing (M6 knife 11 foundation). Pure Dawn over the crypto
# module — reproduces the official qiniu SDK's HMAC-SHA1 signatures so fm can
# mint upload tokens, private download URLs, and management tokens without the
# SDK (which drags okhttp+gson). Cross-checked against the Python qiniu.Auth.
use std/str
use crypto.{hmac_sha1_b64url, b64url_encode}

## The EncodedEntryURI for a management op: base64url(bucket:key), with padding.
pub fn entry_uri(bucket: String, key: String) -> String !io = b64url_encode("$bucket:$key")

## Management token for an entry-based op (stat/delete/copy/move). `op` is the
## verb path segment like "stat", "delete". Returns the QBox Authorization value.
pub fn entry_token(ak: String, sk: String, op: String, entry: String) -> String !io =
  management_token(ak, sk, "/$op/$entry\n")

## QiniuMacAuth token (the statistics API, api.qiniuapi.com). Signs
## "METHOD /path?query\nHost: host\nContent-Type: ct\n\n". Returns the full
## "Qiniu ak:sign" Authorization value.
pub fn qiniu_mac_token(ak: String, sk: String, method: String, path: String, query: String, host: String, content_type: String) -> String !io =
  qiniu_mac(ak, sk, method, "$path?$query", host, content_type, "")

## General QiniuMacAuth (CDN / billing APIs too): `path_query` is the path with
## its query string if any; `body` participates in the signature for JSON
## requests (matches the SDK: body is appended when content-type is set and
## not application/octet-stream).
pub fn qiniu_mac(ak: String, sk: String, method: String, path_query: String, host: String, content_type: String, body: String) -> String !io = {
  let signing = "$method $path_query\nHost: $host\nContent-Type: $content_type\n\n$body"
  let sign = hmac_sha1_b64url(sk, signing)
  "Qiniu $ak:$sign"
}

## Upload token for a specific key (spec: putPolicy → base64 → HMAC-SHA1 → token).
## putPolicy is {"scope":"bucket:key","deadline":<unix>} in that key order (the
## qiniu SDK's dict order), so the base64 matches byte-for-byte.
pub fn upload_token(ak: String, sk: String, bucket: String, key: String, deadline: Int) -> String !io = {
  # compact JSON, no spaces — matches the qiniu SDK's json.dumps output so the
  # base64 and therefore the signature match byte-for-byte
  let policy = "{\"scope\":\"$bucket:$key\",\"deadline\":$deadline}"
  let encoded_policy = b64url_encode(policy)
  let sign = hmac_sha1_b64url(sk, encoded_policy)
  "$ak:$sign:$encoded_policy"
}

## A private download URL: append ?e=<deadline>, sign the whole thing, append
## &token=ak:sign. `base_url` is the full https URL (with any imageView2 fop).
pub fn private_url(ak: String, sk: String, base_url: String, deadline: Int) -> String !io = {
  let sep = if str.contains(base_url, "?") { "&" } else { "?" }
  let signed_url = "$base_url${sep}e=$deadline"
  let sign = hmac_sha1_b64url(sk, signed_url)
  "$signed_url&token=$ak:$sign"
}

## Management token (QBox) for BucketManager ops. `signing_str` is
## "<path>?<query>\n" (plus the form body when the content type is form-encoded).
pub fn management_token(ak: String, sk: String, signing_str: String) -> String !io = {
  let sign = hmac_sha1_b64url(sk, signing_str)
  "QBox $ak:$sign"
}

test "signatures match the qiniu SDK byte-for-byte" {
  # cross-checked against qiniu.Auth("AKtest","SKtest") with fixed deadline
  assert upload_token("AKtest", "SKtest", "mybucket", "path/to/key.jpg", 1783976183) ==
    "AKtest:LdlhAwhBCGjF3a-wmS6FRzyLyik=:eyJzY29wZSI6Im15YnVja2V0OnBhdGgvdG8va2V5LmpwZyIsImRlYWRsaW5lIjoxNzgzOTc2MTgzfQ=="
  assert private_url("AKtest", "SKtest", "https://cdn.example.com/a.jpg", 1783976183) ==
    "https://cdn.example.com/a.jpg?e=1783976183&token=AKtest:qds6pILEK2BxpimglNVjrgvF1nU="
  assert management_token("AKtest", "SKtest", "/stat/abc\n") == "QBox AKtest:uq4LtkfJVo-ZNXoftWh9gv1-zVs="
  assert entry_uri("mybucket", "path/to/file.jpg") == "bXlidWNrZXQ6cGF0aC90by9maWxlLmpwZw=="
  let entry = entry_uri("mybucket", "path/to/file.jpg")
  assert entry_token("AKtest", "SKtest", "stat", entry) == "QBox AKtest:a7a0HH5stgcmowbc-vWoHroXYJU="
  assert entry_token("AKtest", "SKtest", "delete", entry) == "QBox AKtest:-7Eh_fzs9TcII1AZPjkouLF26fc="
  assert qiniu_mac_token("AKtest", "SKtest", "GET", "/v6/space", "bucket=mybucket&begin=20260701000000&end=20260714120000&g=day", "api.qiniuapi.com", "application/x-www-form-urlencoded") ==
    "Qiniu AKtest:4tea02U1hxRrkWbTP1pUcrBOqmo="
  # cross-checked against qiniu.QiniuMacAuth("AKtest","SKtest").token_of_request
  assert qiniu_mac("AKtest", "SKtest", "POST", "/v2/tune/flux", "fusion.qiniuapi.com", "application/json",
      "{\"domains\":\"a.com;b.com\",\"startDate\":\"2026-06-14\",\"endDate\":\"2026-07-14\",\"granularity\":\"day\"}") ==
    "Qiniu AKtest:716FuHT8Wo0muPljCsrV9uNPuxE="
  assert qiniu_mac("AKtest", "SKtest", "GET", "/domain?limit=100", "api.qiniu.com", "application/json", "") ==
    "Qiniu AKtest:NkIHWnHFAVdnaXMKYl-2OE1foYk="
  assert qiniu_mac("AKtest", "SKtest", "GET", "/billing-api/v1/respack/list", "api.qiniu.com", "application/json", "") ==
    "Qiniu AKtest:0ymmWdvrL7R-Ru70v3DT0glRFic="
}
