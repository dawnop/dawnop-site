# The server: jdk.httpserver underneath (spec §9 interop), one virtual thread
# per request, a single root context that parses the exchange into a Request,
# routes it, and writes the Response back. nginx terminates TLS and everything
# hard in front — this only speaks HTTP/1.1.
use java "com.sun.net.httpserver.HttpServer"
use java "com.sun.net.httpserver.HttpExchange"
use java "com.sun.net.httpserver.Headers"
use java "java.net.InetSocketAddress"
use java "java.util.concurrent.Executors"
use java "java.util.concurrent.CountDownLatch"
use java "java.io.OutputStreamWriter"
use java "java.lang.String"
use java "java.util.Iterator"
use java "java.io.File"
use java "java.io.FileOutputStream"
use web/types.{Request, Response, HttpError, Handler, Middleware, RouteMeta, http_error, error_response}
use web/router.{Route, Dispatch, Found, NoPath, WrongMethod, dispatch, route_meta}

# Read the whole request body once as Bytes (spec §9.5.1), plus its UTF-8 decode
# for the common text/JSON/form handlers. Binary handlers (multipart upload,
# WebDAV PUT) take the raw Bytes and recover exact file bytes with no latin-1
# detour — a single decode, not two.
fn read_body(ex: HttpExchange) -> (String, Bytes) !io = {
  let stream = ex.getRequestBody()!
  let bytes = stream.readAllBytes()!
  (decode(bytes, "UTF-8"), bytes)
}

# Write a response. Length 0 selects chunked transfer encoding, so we never
# need the byte count up front; the Writer handles UTF-8.
fn write_response(ex: HttpExchange, r: Response) -> Unit !io = {
  let headers = ex.getResponseHeaders()!
  headers.set("Content-Type", r.content_type)
  set_extra_headers(headers, r.headers)
  ex.sendResponseHeaders(r.status, 0)
  let out = ex.getResponseBody()!
  match r.bin {
    Some(bytes) -> {
      # binary body: write the raw Bytes verbatim (Bytes -> Java byte[] param)
      out.write(bytes)
      out.flush()
    }
    None -> {
      let writer = OutputStreamWriter.new(out, "UTF-8")
      writer.write(r.body)
      writer.flush()
      writer.close()
    }
  }
  out.close()
  ex.close()
}

fn set_extra_headers(headers: Headers, hs: List[(String, String)]) -> Unit !io = {
  for i in range(0, len(hs)) {
    let (k, v) = hs[i]
    headers.add(k, v)
  }
}

# Collect request headers into a lowercase-keyed map (first value per name;
# multi-valued request headers are rare in this API and the first wins). The
# key set is a Java collection, so it is walked with an iterator.
fn read_headers(ex: HttpExchange) -> Map[String, String] !io = {
  let headers = ex.getRequestHeaders()!
  let it = headers.keySet()!.iterator()!
  collect_headers(headers, it, map_empty())
}

fn collect_headers(headers: Headers, it: Iterator, acc: Map[String, String]) -> Map[String, String] !io =
  if it.hasNext() {
    let name = String.valueOf(it.next()!)!
    let v = headers.getFirst(name)!
    collect_headers(headers, it, map_insert(acc, to_lower(name), v))
  } else {
    acc
  }

# "a=1&b=x" -> [("a","1"),("b","x")]. URI.getQuery() hands us the string
# already percent-decoded; a value may itself contain '=', so only the first
# one splits.
pub fn parse_query(q: String) -> List[(String, String)] =
  map(filter(split(q, "&"), fn(pair) => pair != ""), fn(pair) => {
    let parts = split(pair, "=")
    (parts[0], join(tail(parts), "="))
  })

# Parse an application/x-www-form-urlencoded body into a map. Same grammar as a
# query string but '+' also means space; percent-decoding is the caller's if
# needed (login/form fields here are ASCII).
pub fn parse_form(body: String) -> Map[String, String] =
  map_from(map(parse_query(body), fn(kv) => {
    let (k, v) = kv
    (k, replace_plus(v))
  }))

fn replace_plus(s: String) -> String = join(split(s, "+"), " ")

fn tail(xs: List[String]) -> List[String] =
  map(range(1, len(xs)), fn(i) => xs[i])

fn rev[T](xs: List[T]) -> List[T] =
  map(range(0, len(xs)), fn(i) => xs[len(xs) - 1 - i])

fn build_request(ex: HttpExchange, meta: Option[RouteMeta]) -> Request !io = {
  let uri = ex.getRequestURI()!
  let no_query: Map[String, String] = map_from([])
  # Query params follow form-urlencoded semantics ('+' means space), matching
  # Starlette/FastAPI; URI.getQuery() percent-decodes %XX but leaves '+' literal.
  let q = match uri.getQuery() {
    Some(s) -> map_from(map(parse_query(s), fn(kv) => {
      let (k, v) = kv
      (k, replace_plus(v))
    }))
    None -> no_query
  }
  # A "stream-body" route never sees the body in memory: it goes to a temp file
  # and the handler gets the path. Everything else reads as before.
  let streaming = meta_has_tag(meta, "stream-body")
  let (body, raw) = if streaming { ("", utf8("")) } else { read_body(ex) }
  let bf: Option[String] = if streaming { Some(spill_body(ex)) } else { None }
  Request {
    method: ex.getRequestMethod()!,
    path: uri.getPath()!,
    params: no_query,
    query: q,
    headers: read_headers(ex),
    body: body,
    raw: raw,
    body_file: bf,
    route: meta,
  }
}

# Stream the request body to a temp file, 8KB at a time (transferTo's buffer), and
# return its path. Constant memory whatever the file's size — the point of the
# whole exercise. The caller deletes it once the handler is done.
fn spill_body(ex: HttpExchange) -> String !io = {
  let tmp = File.createTempFile("dawn-put-", ".tmp")!
  let out = FileOutputStream.new(tmp)
  let stream = ex.getRequestBody()!
  let _n = stream.transferTo(out)
  out.close()
  String.valueOf(tmp.getPath()!)!
}

fn delete_quietly(path: String) -> Unit !io = {
  let r: Result[Bool, String] = java_try(fn() => File.new(path).delete())
  match r {
    Ok(_) -> ()
    Err(m) -> println("temp body file not deleted: $m")
  }
}

fn meta_has_tag(meta: Option[RouteMeta], tag: String) -> Bool =
  match meta {
    Some(m) -> find(m.tags, fn(t) => t == tag) != None
    None -> false
  }

# Execute an already-computed dispatch decision, itself shaped like a handler so
# middleware can wrap it — a logging middleware sees 404s and 405s too. The
# matched route's captures are injected as a fresh Request (records are immutable).
fn run_dispatch(d: Dispatch, req: Request) -> Result[Response, HttpError] !io =
  match d {
    NoPath -> Err(http_error(404, "Not Found"))
    WrongMethod -> Err(http_error(405, "Method Not Allowed"))
    Found(route, params) -> {
      route.handler(Request { ..req, params: params })
    }
  }

# The metadata middleware get for the matched route. Unmatched (404) and
# wrong-method (405) requests carry no route, hence no tags.
fn meta_of(d: Dispatch) -> Option[RouteMeta] =
  match d {
    Found(route, _) -> Some(route_meta(route))
    NoPath -> None
    WrongMethod -> None
  }

fn handle(routes: List[Route], middleware: List[Middleware], ex: HttpExchange) -> Unit !io = {
  # a handler panic is isolated to this request: catch_panic turns it into a 500
  # instead of resetting the connection or leaking the virtual thread (spec §9.8).
  let outcome = catch_panic(fn() => {
    # Dispatch BEFORE touching the body: method and path come from the request
    # line, and the matched route's tags decide how the body is read at all
    # ("stream-body" spills it to disk instead of into memory). The same decision
    # is executed by run_dispatch below — no second table walk.
    let d = dispatch(routes, ex.getRequestMethod()!, ex.getRequestURI()!.getPath()!)
    let req = build_request(ex, meta_of(d))
    # first middleware in the list is outermost: [a, b] runs a(b(core)). Middleware
    # still wraps the core, so CORS preflight and logging cover unmatched requests.
    let app = fold(rev(middleware), fn(rq: Request) => run_dispatch(d, rq), fn(h, m) => m(h))
    # the temp body file lives exactly as long as the handler call. Dawn has no
    # try/finally, so catch_panic plays that role (same idiom as with_tx): it
    # returns rather than unwinding, so the delete below always runs.
    let served = catch_panic(fn() => app(req))
    match req.body_file {
      Some(p) -> delete_quietly(p)
      None -> ()
    }
    match served {
      Ok(Ok(r)) -> r
      Ok(Err(e)) -> error_response(e)
      Err(m) -> {
        println("request panicked: $m")
        error_response(http_error(500, "服务器内部错误"))
      }
    }
  })
  let response = match outcome {
    Ok(r) -> r
    Err(m) -> {
      println("request panicked: $m")
      error_response(http_error(500, "服务器内部错误"))
    }
  }
  write_response(ex, response)
}

# Start on 127.0.0.1:port and block forever (main() returning would let the
# JVM exit out from under the request threads).
pub fn serve_app(port: Int, routes: List[Route], middleware: List[Middleware]) -> Unit !io = {
  let addr = InetSocketAddress.new("127.0.0.1", port)
  let server = HttpServer.create(addr, 0)!
  server.createContext("/", fn(ex) => handle(routes, middleware, ex))
  server.setExecutor(Executors.newVirtualThreadPerTaskExecutor()!)
  server.start()
  println("listening on http://127.0.0.1:$port")
  let latch = CountDownLatch.new(1)
  latch.await()
}

test "query strings parse, including empty and embedded =" {
  assert parse_query("a=1&b=x") == [("a", "1"), ("b", "x")]
  assert parse_query("") == []
  assert parse_query("k=a=b") == [("k", "a=b")]
  assert parse_query("flag") == [("flag", "")]
}

test "form bodies parse, with + as space" {
  let f = parse_form("username=admin&password=a+b+c")
  assert map_get(f, "username") == Some("admin")
  assert map_get(f, "password") == Some("a b c")
}
