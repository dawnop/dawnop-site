# 复制为 backend/.env 并填入真实值；.env 不会被提交。

# ---- 应用 ----
APP_NAME=dawnop-site
# 生成: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- 数据库 ----
# 本地开发用相对路径即可（库落在 backend/ 下）。
# ⚠️ 生产必须改成绝对路径指向共用库：DATABASE_URL=sqlite:////opt/dawnop/data/dawnop.db
#    （四个斜杠）。M6 之后 Dawn 后端与本实现共用同一个 SQLite 文件（WAL），库在
#    /opt/dawnop/data/ 而不是这里；留着下面这个相对默认值，回滚到 FastAPI 时会静默
#    打开一个 M6 之前的旧库——不报错，只是数据回到过去。详见 deploy/README.md。
DATABASE_URL=sqlite:///./dawnop.db

# ---- 中文分词扩展（wangfenjin/simple，可选）----
# 留空用默认 backend/extensions/libsimple（跑 scripts/fetch_simple_ext.py 下载）。
# 缺文件时搜索自动退回 trigram/LIKE，不影响启动。
SIMPLE_EXTENSION_PATH=

# ---- CORS（前端开发地址，逗号分隔）----
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- 七牛云 Kodo ----
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
# 绑定到 bucket 的下载域名，如 https://cdn.dawnop.com
QINIU_DOMAIN=
# 私有空间下载链接有效期（秒）
QINIU_TOKEN_EXPIRES=3600
# 存储配额（GB），仅文件管理侧栏用量条展示；七牛标准存储免费额度 10GB
STORAGE_QUOTA_GB=10

# ---- 腾讯云（后台监控页；建议用只读子账号密钥，非主账号）----
# 权限：lighthouse:Describe* + monitor:GetMonitorData + monitor:DescribeBaseMetrics。
# 留空则监控页「腾讯云」块只显示本机指标（流量包/到期不可用）。
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
# 本站服务器（Lighthouse 轻量应用服务器）所在地域与实例 ID
TENCENT_REGION=ap-shanghai
LIGHTHOUSE_INSTANCE_ID=lhins-8clkew6k

# ---- Vaultwarden 存活探测（监控页「Vault」块）----
# 后端与容器同机时走内网；容器只监听 127.0.0.1:8222
VAULT_ALIVE_URL=http://127.0.0.1:8222/alive
# 监控页上「打开 Vault」链接指向的公网地址（探测走上面的内网地址，这个只用于展示）
VAULT_PUBLIC_URL=https://vault.dawnop.com

# ---- 初始管理员（仅 seed_admin.py 使用）----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
