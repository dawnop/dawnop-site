# 复制为 .env（同目录，不提交）后填真实值。
# 生成 ADMIN_TOKEN（在服务器上，argon2 哈希形式，推荐）：
#   docker run --rm -it vaultwarden/server:1.36.0-alpine /vaultwarden hash
# 把它输出的整串（形如 $argon2id$v=19$...）粘到下面（注意 .env 里 $ 无需转义，但用单引号包更稳）。

# 首次注册时临时设 true，注册完自己的账号后改回 false，再 `docker compose up -d` 重建容器。
SIGNUPS_ALLOWED=false

# /admin 面板令牌（argon2 哈希）。留空则不开放 /admin。
ADMIN_TOKEN=
